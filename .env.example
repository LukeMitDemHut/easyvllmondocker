# HuggingFace Configuration
HUGGINGFACE_CACHE=${HOME}/.cache/huggingface
HF_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN_HERE

# Container Image Configuration
VLLM_IMAGE=vllm/vllm-openai:v0.20.2-cu129
# Optional: set to linux/arm64 on DGX Spark if Docker does not select ARM64 automatically.
VLLM_PLATFORM=
LITELLM_IMAGE=ghcr.io/berriai/litellm:litellm_stable_v1_82_3-v1.82.3
POSTGRES_IMAGE=postgres:16-alpine
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter:v1.11.1
DCGM_EXPORTER_IMAGE=nvcr.io/nvidia/k8s/dcgm-exporter:4.4.1-4.6.0-ubuntu22.04
GRAFANA_IMAGE=grafana/grafana:13.0.1

# DCGM Exporter Configuration
# Optional: set to host.docker.internal:5555 on DGX systems with host nv-hostengine.
DCGM_REMOTE_HOSTENGINE_INFO=
DCGM_EXPORTER_DEVICES_STR=f
DCGM_EXPORTER_INTERVAL=30000

# Gateway Configuration
GATEWAY_PORT=8000

# Database Configuration
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# LiteLLM Configuration
LITELLM_MASTER_KEY=sk-YOUR_MASTER_KEY_HERE
LITELLM_SALT_KEY=YOUR_RANDOM_SALT_KEY_HERE
LITELLM_USERNAME=admin
LITELLM_PASSWORD=CHANGE_ME_STRONG_PASSWORD
LITELLM_NUM_WORKERS=4

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
